# Copy to backend/.env for local (non-Docker) development.

# SQLite needs nothing else; for the compose Postgres use:
# DATABASE_URL=postgresql+asyncpg://quwwa:quwwa@localhost:5433/quwwa
DATABASE_URL=sqlite+aiosqlite:///./quwwa.db

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — form-video search falls back to scraping when unset.
YOUTUBE_API_KEY=
